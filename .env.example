# FieldPulse Backend Environment Variables
# Copy this to .env and fill in values before running

# Django
SECRET_KEY=your-long-random-secret-key-here-minimum-50-chars
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DB_NAME=fieldpulse
DB_USER=fieldpulse
DB_PASSWORD=fieldpulse
DB_HOST=db
DB_PORT=5432

# MinIO / S3
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fieldpulse
MINIO_ENDPOINT=http://minio:9000

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Push notifications (optional — app works without it)
FCM_SERVER_KEY=

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
DJANGO_LOG_LEVEL=INFO
